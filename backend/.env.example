# ─────────────────────────────────────────────────────────────
# FluxKart Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=           # CHANGE THIS
POSTGRES_DB=fluxkart_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=fluxkart
RABBITMQ_PASSWORD=           # CHANGE THIS

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# Rate Limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# Reservation TTL (seconds a reservation is held before releasing inventory)
RESERVATION_TTL_SECONDS=600

# JWT — CHANGE JWT_SECRET_KEY before deploying to production
JWT_SECRET_KEY=              # CHANGE THIS — use a long random string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Observability
JAEGER_OTLP_ENDPOINT=http://jaeger:4317

# Grafana
GF_SECURITY_ADMIN_PASSWORD=  # CHANGE THIS