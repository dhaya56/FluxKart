# ─────────────────────────────────────────────────────────────
# FluxKart Monorepo .gitignore
# ─────────────────────────────────────────────────────────────

# ── Environment variables — NEVER commit these ───────────────
.env
backend/.env

# ── Python cache ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────
.venv/
env/
venv/

# ── Anaconda ──────────────────────────────────────────────────
*.conda

# ── Distribution / packaging ──────────────────────────────────
dist/
build/
*.egg-info/

# ── Testing ───────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── IDE ───────────────────────────────────────────────────────
.vscode/settings.json
.idea/

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Alembic — keep versions, ignore compiled cache ───────────
backend/alembic/__pycache__/

# PgBouncer credentials — contains database password
backend/pgbouncer/userlist.txt

# ── Load test tokens — contains JWT tokens, never commit ──────
backend/scripts/tokens.json

# ── Frontend ──────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.production